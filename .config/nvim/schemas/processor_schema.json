{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "ProcessorSchema",
	"type": "object",
	"properties": {
		"processors": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "data_width"],
				"properties": {
					"name": { "type": "string" },
					"data_width": { "type": "integer" },
					"address_width": { "type": "integer" },
					"release": { "type": "string", "format": "date" },
					"manufacturer": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": { "type": "string"}
							}
						}
					},
					"packages": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": { "type": "string" },
								"pins": { "type": "integer" }
							}
						}
					},
					"clock": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"value": { "type": "float" },
								"unit": { "type": "string" }
							}
						}
					},
					"technology": { "type": "string" },
					"transistors": { "type": "integer" },
					"instruction_set": { "type": "string" },
					"related_to": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": { "type": "string" },
								"type": { "type": "string" }
							}
						}
					}
				}
			}
		}
	}
}
